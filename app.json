{
  "expo": {
    "owner": "handwrittenai",
    "name": "handwrittenAI",
    "slug": "handwrittenAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo-aiscorer.png",
    "backgroundColor": "#0EA47A",
    "splash": {
      "image": "./src/assets/images/logo-aiscorer.png",
      "resizeMode": "contain",
      "backgroundColor": "#0EA47A"
    },
    "scheme": "handwrittenai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.handwrittenai.handwrittenAI",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0EA47A",
        "foregroundImage": "./src/assets/images/logo-aiscorer.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.handwrittenai.handwrittenAI"
    },
    "web": {
      "output": "single",
      "favicon": "./src/assets/images/logo-aiscorer.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logo-aiscorer.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0EA47A",
          "dark": {
            "backgroundColor": "#0EA47A"
          }
        }
      ]
    ],
    "extra": {
      "googleAuth": {
        "expoClientId": "1093390926434-ivcngaqpp8d139mp915cdit1ip5v7ggs.apps.googleusercontent.com",
        "iosClientId": "1093390926434-d0uvi309ncnc8qhhm9rl7b5p6l0t63lm.apps.googleusercontent.com",
        "androidClientId": "1093390926434-49tbmc9iaksm03jaltp34odcoo1sq6kh.apps.googleusercontent.com",
        "webClientId": "1093390926434-ur1pmp59h84rjdmdan930ogjj25742fa.apps.googleusercontent.com"
      },
      "router": {},
      "eas": {
        "projectId": "a3684295-85f0-4b29-8eef-ce073c371b83"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
